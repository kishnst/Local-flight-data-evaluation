# AviationStack (https://aviationstack.com/documentation)
AVIATIONSTACK_API_KEY=your_api_key_here

# PostgreSQL (Docker maps host 5050 -> container 5432)
DB_HOST=localhost
DB_PORT=5050
DB_NAME=flight_analytics
DB_USER=postgres
DB_PASSWORD=postgres

# Optional: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
