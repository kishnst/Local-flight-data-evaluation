# Copy to .env before: docker compose up --build

AVIATIONSTACK_API_KEY=your_api_key_here

DB_HOST=postgres
DB_PORT=5432
DB_NAME=airline_analytics
DB_USER=dev
DB_PASSWORD=dev

LOG_LEVEL=INFO
POLL_INTERVAL_SECONDS=300
MAX_PAGES_PER_DIRECTION=5
PAGE_DELAY_SECONDS=1.0

# Airflow (optional override)
AIRFLOW_FERNET_KEY=dGVzdGZlcm5ldGtleXRlc3Rmb3Jsb2NhbGRldg==
